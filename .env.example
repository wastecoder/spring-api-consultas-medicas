# Copie este arquivo para `.env` e preencha os valores reais.
# O `.env` está ignorado pelo Git.

# --- JWT (caminhos para os arquivos PEM) ---
# Use prefixo `file:` para caminho no filesystem ou `classpath:` para classpath.
JWT_PRIVATE_KEY_PATH=file:./keys/jwt-private.key
JWT_PUBLIC_KEY_PATH=file:./keys/jwt-public.key

# --- Admin bootstrap (usuário criado no primeiro start) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- Postgres (perfil dev) ---
DB_PASSWORD=changeme

# --- Postgres (perfil docker) ---
DB_NAME=consultas_medicas
DB_USER=postgres
# DB_PASSWORD já listado acima

# --- Produção (perfil prod, ex.: Railway) ---
# DATABASE_URL deve estar no formato JDBC com user/senha embutidos como query params,
# ou então usar SPRING_DATASOURCE_USERNAME/SPRING_DATASOURCE_PASSWORD separadamente.
# SPRING_PROFILES_ACTIVE=prod
# DATABASE_URL=jdbc:postgresql://<host>:<port>/<db>?user=<u>&password=<p>
